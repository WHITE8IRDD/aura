    "typescript": "^5.5.3",
    "vite": "^5.3.4"
  },
  "dependencies": {
    "@cliqz/adblocker-electron": "^1.34.0",
    "better-sqlite3": "^12.11.1",
    "cross-fetch": "^4.1.0",
    "framer-motion": "^12.40.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
